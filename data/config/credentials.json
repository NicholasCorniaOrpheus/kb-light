{
	"kblight": {
		"base_url": "https://{github_user}.github.com/{github_repo}/entity/",
		"assets_url": "https://raw.githubusercontent.com/{github_user}/{github_repo}/refs/heads/main/{path_to_file}"
	},

	"transkribus": {
		"user": "{USER}",
		"password": "{PASSWORD}",
		"auth_url": "https://account.readcoop.eu/auth/realms/readcoop/protocol/openid-connect/token",
		"api_url": "https://transkribus.eu/processing/v1",
		"api_schema": "https://transkribus.eu/processing/v1/openapi.json"

	},

	"wikidata": {
    "username": "{USERNAME}",
    "password": "{PASSWORD}",
    "consumer_token": "{TOKEN}",
    "consumer_secret": "{TOKEN_SECRET}",
    "access_token": "{ACCESS_TOKEN}",
    "mediawiki_api_url": "https://www.wikidata.org/w/api.php"

	}	

}